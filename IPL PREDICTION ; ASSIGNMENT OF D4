import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

#Load dataset
df=pd.read_excel("ipl_team_performance_2024_2025.xlsx")
print(df)

df["Win_Percentage"] = (df["Wins"] / df["Matches_Played"]) * 100
df["Performance_Score"] = (
    0.6 * df["Points"] +        # strongest factor
    0.3 * df["Win_Percentage"] + 
    10 * df["Net_Run_Rate"]     # scale up NRR manually
)
team_score = df.groupby("Team")["Performance_Score"].mean().reset_index()
team_score = team_score.sort_values(by="Performance_Score", ascending=False)

print(team_score)
print("🏆 Predicted Winner:", team_score.iloc[0]["Team"])

#scatterplot:team vs point
sns.scatterplot(x="Team",y="Points",data=df)
plt.title("Team vs Points, coloured by Wins")
plt.xlabel("Team")
plt.ylabel("Points")
plt.show()

