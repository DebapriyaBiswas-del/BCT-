import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

#Load dataset
df=sns.load_dataset("titanic")

#Fare vs Age by coloured
sns.scatterplot(x="age",y="fare",hue="survived",data=df)
plt.title("Fare vs Age, coloured by survival")
plt.xlabel("Age")
plt.ylabel("Fare")
plt.show()

#correlation matrix
corr=df[['age','fare','survived']].corr()
sns.heatmap(corr,annot=True,cmap="cividis")
plt.title("Correlation Matrix")
plt.show()


#Fill missing age values with mean()
df['age']=df['age'].fillna(df['age'].mean())


df.head()

#filling embark
df['embark_town']=df['embark_town'].fillna('unknown')
print(df)

#Drop rows with missing deck
df=df.dropna(subset=['deck'])
print(df)
print(df.isnull().sum())


#Survival rate by class
survival_rate_by_class=df.groupby("class")["survived"].mean()
print(survival_rate_by_class)

#survival rate by gender and class
survival_rate_by_gender_class=df.groupby(["sex","class"])["survived"].mean()
print(survival_rate_by_gender_class)

#
sns.barplot(x="class",y="survived",data=df)
plt.title("Survival Rate by Gender")
plt.xlabel("Gender")
plt.ylabel("Survival Rate")
plt.show()



#heatmap
pivot=df.pivot_table(index="class",columns="sex",values="survived",aggfunc="mean")
sns.heatmap(pivot,annot=True,cmap="Blues")
plt.title("Survival Rate by Gender and class")
plt.show()
